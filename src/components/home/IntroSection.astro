---
import Container from "../ui/Container.astro";
import Reveal from "../ui/Reveal.astro";
---

<section class="border-t border-white/10 py-28">
  <Container>
    <Reveal>
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-[#C8A96B] uppercase tracking-[0.35em] text-xs">
          Plataforma de inteligencia
        </p>

        <h2 class="mt-6 text-4xl md:text-6xl font-semibold leading-tight tracking-[-0.04em]">
          Un espacio para aprender, investigar y convertir evidencia en estrategia.
        </h2>

        <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-white/55">
          ForenseIA reúne contenido especializado, cursos, análisis técnico y servicios profesionales para quienes necesitan entender información compleja con claridad, método y criterio.
        </p>
      </div>
    </Reveal>
  </Container>
</section>