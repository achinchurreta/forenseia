---
import "../../styles/global.css";
import DashboardGuard from "../auth/DashboardGuard.astro";

interface Props {
  title?: string;
}

const { title = "Dashboard | ForenseIA" } = Astro.props;

const nav = [
  { label: "Inicio", href: "/dashboard" },
  { label: "Posts", href: "/dashboard/posts" },
  { label: "Cursos", href: "/dashboard/cursos" },
  { label: "Casos", href: "/dashboard/casos" },
  { label: "Ver sitio", href: "/" },
];
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="bg-black text-white antialiased">
    <DashboardGuard />

    <div class="min-h-screen grid lg:grid-cols-[280px_1fr]">
      <aside class="border-r border-white/10 bg-white/[0.02] p-6">
        <div class="flex items-center gap-3 mb-10">
          <img
            src="/logo.png"
            alt="ForenseIA"
            class="w-11 h-11 object-contain"
          />

          <div>
            <p class="font-semibold">FORENSEIA</p>
            <p class="text-[#C8A96B] text-xs tracking-widest uppercase">
              Admin
            </p>
          </div>
        </div>

        <nav class="space-y-2">
          {nav.map((item) => (
            <a
              href={item.href}
              class="block rounded-xl px-4 py-3 text-white/60 transition hover:bg-white/[0.04] hover:text-[#C8A96B]"
            >
              {item.label}
            </a>
          ))}

          <button
            id="logout-button"
            type="button"
            class="block w-full text-left rounded-xl px-4 py-3 text-white/60 hover:bg-white/[0.04] hover:text-red-300 transition"
          >
            Cerrar sesión
          </button>
        </nav>
      </aside>

      <main class="p-6 lg:p-10">
        <slot />
      </main>
    </div>

    <script is:inline>
      const logoutButton = document.getElementById("logout-button");

      logoutButton?.addEventListener("click", () => {
        localStorage.removeItem("forenseia_user_email");
        window.location.href = "/login";
      });
    </script>
  </body>
</html>