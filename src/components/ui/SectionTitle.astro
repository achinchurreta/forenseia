---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  <span class="text-[#C8A96B] uppercase tracking-[0.35em] text-xs">
    {eyebrow}
  </span>

  <h2 class="text-3xl md:text-5xl font-semibold leading-tight mt-4">
    {title}
  </h2>

  {description && (
    <p class="text-white/55 text-lg leading-relaxed mt-5">
      {description}
    </p>
  )}
</div>