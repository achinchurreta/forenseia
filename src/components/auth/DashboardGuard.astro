<script is:inline>
  async function checkDashboardAccess() {
    try {
      const response = await fetch("/.netlify/functions/auth-check", {
        method: "GET",
        credentials: "include",
      });

      if (!response.ok) {
        window.location.href = "/login";
      }
    } catch (error) {
      window.location.href = "/login";
    }
  }

  checkDashboardAccess();
</script>