---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import Container from "../components/ui/Container.astro";
import DiagnosticForm from "../components/forms/DiagnosticForm.astro";
---

<BaseLayout
  title="Contacto | ForenseIA"
  description="Solicita un diagnóstico o ponte en contacto con ForenseIA."
>
  <PageHeader
    eyebrow="Contacto"
    title="Hablemos de tu caso."
    description="Solicita un análisis inicial, capacitación o diagnóstico estratégico."
  />

  <section class="py-24">
    <Container>
      <DiagnosticForm />
    </Container>
  </section>
</BaseLayout>