---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Login | ForenseIA">
  <section class="min-h-screen flex items-center justify-center px-6 pt-24">
    <div class="w-full max-w-md border border-white/10 bg-white/[0.03] p-8">
      <h1 class="text-3xl font-semibold">Acceso ForenseIA</h1>

      <p class="text-white/50 mt-3">
        Ingresa al panel administrativo.
      </p>

      <form id="login-form" class="space-y-5 mt-8">
        <input
          id="email"
          type="email"
          placeholder="Correo"
          required
          class="w-full bg-black border border-white/10 px-4 py-4 text-white outline-none focus:border-[#C8A96B]"
        />

        <input
          id="password"
          type="password"
          placeholder="Contraseña"
          required
          class="w-full bg-black border border-white/10 px-4 py-4 text-white outline-none focus:border-[#C8A96B]"
        />

        <button
          type="submit"
          class="w-full bg-[#C8A96B] text-black px-6 py-4 font-medium"
        >
          Entrar
        </button>

        <p id="message" class="text-white/50"></p>
      </form>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById("login-form");
    const email = document.getElementById("email");
    const password = document.getElementById("password");
    const message = document.getElementById("message");

    form?.addEventListener("submit", (event) => {
      event.preventDefault();

      const allowedEmail = "augustochinchurreta@gmail.com";
      const allowedPassword = "ForenseIA2026";

      if (email.value === allowedEmail && password.value === allowedPassword) {
        localStorage.setItem("forenseia_user_email", email.value);
        window.location.href = "/dashboard";
      } else {
        message.textContent = "Correo o contraseña incorrectos.";
      }
    });
  </script>
</BaseLayout>