---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import { services } from "../data/services";
import { courses } from "../data/courses";
import { posts } from "../data/posts";
import MethodPreview from "../components/home/MethodPreview.astro";
---

<BaseLayout title="ForenseIA | Inteligencia Estratégica">

  <section class="relative min-h-screen flex items-center overflow-hidden pt-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(200,169,107,0.14),transparent_35%)]"></div>

    <Container class="relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="max-w-2xl">
          <span class="text-[#C8A96B] uppercase tracking-[0.35em] text-sm">
            Inteligencia estratégica
          </span>

          <h1 class="text-4xl md:text-6xl font-semibold leading-[1.05] mt-6">
            Convertimos información compleja en inteligencia accionable.
          </h1>

          <p class="text-white/60 text-lg leading-relaxed mt-8">
            ForenseIA integra auditoría forense, OSINT, inteligencia patrimonial,
            ciberseguridad e inteligencia artificial aplicada para investigar,
            enseñar y acompañar decisiones estratégicas.
          </p>

          <div class="flex flex-wrap gap-4 mt-10">
            <a href="/contacto" class="px-7 py-4 bg-[#C8A96B] text-black font-medium hover:opacity-90 transition">
              Solicitar diagnóstico
            </a>

            <a href="/cursos" class="px-7 py-4 border border-white/15 text-white hover:border-[#C8A96B] hover:text-[#C8A96B] transition">
              Ver cursos
            </a>
          </div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <img
            src="/logo.png"
            alt="ForenseIA"
            class="w-[300px] md:w-[420px] object-contain drop-shadow-2xl"
          />
        </div>

      </div>
    </Container>
  </section>

  <section class="border-y border-white/10 bg-white/[0.02] py-24">
    <Container>
      <div class="flex items-end justify-between gap-6 mb-12">
        <SectionTitle
          eyebrow="Servicios"
          title="Áreas de especialización"
          description="Servicios diseñados para análisis, investigación, cumplimiento, formación y toma de decisiones."
        />

        <a href="/servicios" class="hidden md:block text-[#C8A96B]">
          Ver todos →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {services.slice(0, 3).map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            href={service.href}
            label="Ver servicio"
          />
        ))}
      </div>
    </Container>
  </section>

  <section class="py-24">
    <Container>
      <div class="flex items-end justify-between gap-6 mb-12">
        <SectionTitle
          eyebrow="Academia"
          title="Cursos destacados"
          description="Formación especializada para profesionales, instituciones, auditores, investigadores y equipos de cumplimiento."
        />

        <a href="/cursos" class="hidden md:block text-[#C8A96B]">
          Ver cursos →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {courses.map((course) => (
          <ServiceCard
            title={course.title}
            description={course.description}
            href={course.href}
            label="Ver curso"
          />
        ))}
      </div>
    </Container>
  </section>

  <section class="border-t border-white/10 bg-white/[0.02] py-24">
    <Container>
      <div class="flex items-end justify-between gap-6 mb-12">
        <SectionTitle
          eyebrow="Gaceta"
          title="Últimos análisis"
          description="Publicaciones para enseñar, posicionar autoridad y conectar conocimiento técnico con soluciones reales."
        />

        <a href="/blog" class="hidden md:block text-[#C8A96B]">
          Ver blog →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {posts.map((post) => (
          <ServiceCard
            title={post.title}
            description={post.description}
            href={post.href}
            label="Leer artículo"
          />
        ))}
      </div>
    </Container>
  </section>
<MethodPreview />
</BaseLayout>