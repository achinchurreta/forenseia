---
import BaseLayout from "../layouts/BaseLayout.astro";

import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import Button from "../components/ui/Button.astro";
import Reveal from "../components/ui/Reveal.astro";

import IntroSection from "../components/home/IntroSection.astro";
import MethodPreview from "../components/home/MethodPreview.astro";
import AuthoritySection from "../components/home/AuthoritySection.astro";
import FinalCTA from "../components/home/FinalCTA.astro";

import { services } from "../data/services";
import { courses } from "../data/courses";
import { posts } from "../data/posts";
import PlatformSection from "../components/home/PlatformSection.astro";
import SectorsSection from "../components/home/SectorsSection.astro";
import ResourcesSection from "../components/home/ResourcesSection.astro";
import ProcessSection from "../components/home/ProcessSection.astro";
---

<BaseLayout title="ForenseIA | Inteligencia Estratégica">
  <section class="relative min-h-screen flex items-center overflow-hidden pt-24">
    <div class="absolute inset-0 bg-black"></div>
    <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-[#C8A96B]/10 blur-[160px] rounded-full"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-white/[0.03] blur-[140px] rounded-full"></div>
    <div class="absolute inset-0 opacity-[0.03] bg-[linear-gradient(rgba(255,255,255,0.07)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.07)_1px,transparent_1px)] bg-[size:90px_90px]"></div>

    <Container class="relative z-10">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        <Reveal>
          <div class="max-w-2xl">
            <span class="text-[#C8A96B] uppercase tracking-[0.35em] text-sm">
              Inteligencia Estratégica
            </span>

            <h1 class="text-5xl md:text-7xl font-semibold leading-[0.96] tracking-[-0.05em] mt-8">
              Convertimos información compleja en inteligencia accionable.
            </h1>

            <p class="text-white/60 text-lg leading-relaxed mt-10 max-w-xl">
              ForenseIA integra auditoría forense, OSINT, inteligencia patrimonial,
              ciberseguridad e inteligencia artificial aplicada para investigar,
              enseñar y acompañar decisiones estratégicas.
            </p>

            <div class="flex flex-wrap gap-5 mt-12">
              <Button href="/contacto">
                Solicitar diagnóstico
              </Button>

              <Button href="/cursos" variant="secondary">
                Ver cursos
              </Button>
            </div>
          </div>
        </Reveal>

        <Reveal delay={180}>
          <div class="relative flex justify-center lg:justify-end">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-[420px] h-[420px] bg-[#C8A96B]/10 blur-[120px] rounded-full"></div>
            </div>

            <img
              src="/logo.png"
              alt="ForenseIA"
              class="relative z-10 w-[260px] md:w-[420px] object-contain drop-shadow-[0_0_60px_rgba(200,169,107,0.25)]"
            />
          </div>
        </Reveal>
      </div>
    </Container>
  </section>

  <IntroSection />

  <PlatformSection />

  <AuthoritySection />

  <SectorsSection />

  <ResourcesSection />

  <ProcessSection />

  <MethodPreview />

  <section class="border-y border-white/10 bg-white/[0.02] py-28">
    <Container>
      <div class="flex items-end justify-between gap-6 mb-14">
        <Reveal>
          <SectionTitle
            eyebrow="Servicios"
            title="Áreas de especialización"
            description="Servicios diseñados para análisis, investigación, cumplimiento, formación y toma de decisiones."
          />
        </Reveal>

        <a
          href="/servicios"
          class="hidden md:block text-[#C8A96B] hover:opacity-80 transition"
        >
          Ver todos →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {services.slice(0, 3).map((service, index) => (
          <Reveal delay={index * 120}>
            <ServiceCard
              title={service.title}
              description={service.description}
              href={service.href}
              label="Ver servicio"
            />
          </Reveal>
        ))}
      </div>
    </Container>
  </section>

  <section class="py-28">
    <Container>
      <div class="flex items-end justify-between gap-6 mb-14">
        <Reveal>
          <SectionTitle
            eyebrow="Academia"
            title="Cursos destacados"
            description="Formación especializada para profesionales, instituciones, investigadores y equipos de cumplimiento."
          />
        </Reveal>

        <a
          href="/cursos"
          class="hidden md:block text-[#C8A96B] hover:opacity-80 transition"
        >
          Ver cursos →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {courses.map((course, index) => (
          <Reveal delay={index * 120}>
            <ServiceCard
              title={course.title}
              description={course.description}
              href={course.href}
              label="Ver curso"
            />
          </Reveal>
        ))}
      </div>
    </Container>
  </section>

  <section class="border-t border-white/10 bg-white/[0.02] py-28">
    <Container>
      <div class="flex items-end justify-between gap-6 mb-14">
        <Reveal>
          <SectionTitle
            eyebrow="Gaceta"
            title="Últimos análisis"
            description="Publicaciones para enseñar, posicionar autoridad y conectar conocimiento técnico con soluciones reales."
          />
        </Reveal>

        <a
          href="/blog"
          class="hidden md:block text-[#C8A96B] hover:opacity-80 transition"
        >
          Ver blog →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {posts.map((post, index) => (
          <Reveal delay={index * 120}>
            <ServiceCard
              title={post.title}
              description={post.description}
              href={post.href}
              label="Leer artículo"
            />
          </Reveal>
        ))}
      </div>
    </Container>
  </section>

  <MethodPreview />

  <FinalCTA />
</BaseLayout>