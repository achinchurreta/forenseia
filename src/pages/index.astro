---
import BaseLayout from "../layouts/BaseLayout.astro";

import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import Button from "../components/ui/Button.astro";

import MethodPreview from "../components/home/MethodPreview.astro";
import AuthoritySection from "../components/home/AuthoritySection.astro";
import FinalCTA from "../components/home/FinalCTA.astro";

import { services } from "../data/services";
import { courses } from "../data/courses";
import { posts } from "../data/posts";
---

<BaseLayout title="ForenseIA | Inteligencia Estratégica">

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden pt-24">

    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(200,169,107,0.18),transparent_35%)]"></div>

    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_80%,rgba(255,255,255,0.03),transparent_30%)]"></div>

    <div class="absolute inset-0 opacity-[0.04] bg-[url('/grid.svg')]"></div>

    <Container class="relative z-10">

      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- LEFT -->
        <div class="max-w-2xl">

          <span class="text-[#C8A96B] uppercase tracking-[0.35em] text-sm">
            Inteligencia estratégica
          </span>

          <h1 class="text-5xl md:text-7xl font-semibold leading-[0.98] tracking-[-0.04em] mt-6">
            Convertimos información compleja en inteligencia accionable.
          </h1>

          <p class="text-white/60 text-lg leading-relaxed mt-8">
            ForenseIA integra auditoría forense, OSINT, inteligencia patrimonial,
            ciberseguridad e inteligencia artificial aplicada para investigar,
            enseñar y acompañar decisiones estratégicas.
          </p>

          <div class="flex flex-wrap gap-4 mt-10">

            <Button href="/contacto">
              Solicitar diagnóstico
            </Button>

            <Button href="/cursos" variant="secondary">
              Ver cursos
            </Button>

          </div>

        </div>

        <!-- RIGHT -->
        <div class="flex justify-center lg:justify-end">

          <img
            src="/logo.png"
            alt="ForenseIA"
            class="w-[240px] md:w-[340px] object-contain drop-shadow-2xl"
          />

        </div>

      </div>

    </Container>

  </section>

  <!-- AUTHORITY -->
  <AuthoritySection />

  <!-- SERVICES -->
  <section class="border-y border-white/10 bg-white/[0.02] py-24">

    <Container>

      <div class="flex items-end justify-between gap-6 mb-12">

        <SectionTitle
          eyebrow="Servicios"
          title="Áreas de especialización"
          description="Servicios diseñados para análisis, investigación, cumplimiento, formación y toma de decisiones."
        />

        <a
          href="/servicios"
          class="hidden md:block text-[#C8A96B]"
        >
          Ver todos →
        </a>

      </div>

      <div class="grid md:grid-cols-3 gap-6">

        {services.slice(0, 3).map((service) => (

          <ServiceCard
            title={service.title}
            description={service.description}
            href={service.href}
            label="Ver servicio"
          />

        ))}

      </div>

    </Container>

  </section>

  <!-- COURSES -->
  <section class="py-24">

    <Container>

      <div class="flex items-end justify-between gap-6 mb-12">

        <SectionTitle
          eyebrow="Academia"
          title="Cursos destacados"
          description="Formación especializada para profesionales, instituciones, auditores, investigadores y equipos de cumplimiento."
        />

        <a
          href="/cursos"
          class="hidden md:block text-[#C8A96B]"
        >
          Ver cursos →
        </a>

      </div>

      <div class="grid md:grid-cols-3 gap-6">

        {courses.map((course) => (

          <ServiceCard
            title={course.title}
            description={course.description}
            href={course.href}
            label="Ver curso"
          />

        ))}

      </div>

    </Container>

  </section>

  <!-- BLOG -->
  <section class="border-t border-white/10 bg-white/[0.02] py-24">

    <Container>

      <div class="flex items-end justify-between gap-6 mb-12">

        <SectionTitle
          eyebrow="Gaceta"
          title="Últimos análisis"
          description="Publicaciones para enseñar, posicionar autoridad y conectar conocimiento técnico con soluciones reales."
        />

        <a
          href="/blog"
          class="hidden md:block text-[#C8A96B]"
        >
          Ver blog →
        </a>

      </div>

      <div class="grid md:grid-cols-3 gap-6">

        {posts.map((post) => (

          <ServiceCard
            title={post.title}
            description={post.description}
            href={post.href}
            label="Leer artículo"
          />

        ))}

      </div>

    </Container>

  </section>

  <!-- METHOD -->
  <MethodPreview />

  <!-- CTA -->
  <FinalCTA />

</BaseLayout>