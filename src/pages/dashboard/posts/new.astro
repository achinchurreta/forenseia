---
import DashboardLayout from "../../../components/dashboard/DashboardLayout.astro";
---

<DashboardLayout title="Nuevo post | ForenseIA">
  <div class="mb-10">
    <p class="text-[#C8A96B] uppercase tracking-[0.3em] text-xs">
      Blog / Gaceta
    </p>

    <h1 class="text-4xl font-semibold mt-4">
      Nuevo post
    </h1>

    <p class="text-white/50 mt-4">
      Crea un artículo para publicarlo en el blog de ForenseIA.
    </p>
  </div>

  <form id="post-form" class="max-w-4xl space-y-6">
    <input name="title" required placeholder="Título" class="w-full bg-black border border-white/10 px-4 py-4 text-white outline-none focus:border-[#C8A96B]" />

    <input name="slug" required placeholder="slug-del-articulo" class="w-full bg-black border border-white/10 px-4 py-4 text-white outline-none focus:border-[#C8A96B]" />

    <textarea name="description" required placeholder="Descripción SEO" class="w-full bg-black border border-white/10 px-4 py-4 text-white min-h-28 outline-none focus:border-[#C8A96B]"></textarea>

    <select name="category" required class="w-full bg-black border border-white/10 px-4 py-4 text-white outline-none focus:border-[#C8A96B]">
      <option value="Inteligencia Artificial">Inteligencia Artificial</option>
      <option value="Auditoría Forense">Auditoría Forense</option>
      <option value="OSINT">OSINT</option>
      <option value="Ciberseguridad">Ciberseguridad</option>
      <option value="Inteligencia Patrimonial">Inteligencia Patrimonial</option>
      <option value="Gaceta Mundial IA">Gaceta Mundial IA</option>
    </select>

    <textarea name="content" required placeholder="# Escribe aquí el contenido en Markdown" class="w-full bg-black border border-white/10 px-4 py-4 text-white min-h-[420px] outline-none focus:border-[#C8A96B] font-mono"></textarea>

    <button id="publish-button" type="button" class="bg-[#C8A96B] text-black px-8 py-4 font-medium">
      Publicar post
    </button>

    <p id="message" class="text-white/60"></p>
  </form>

  <script is:inline>
    const button = document.getElementById("publish-button");
    const form = document.getElementById("post-form");
    const message = document.getElementById("message");

    button?.addEventListener("click", async () => {
      if (!form || !message) return;

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      message.textContent = "Publicando...";

      try {
        const response = await fetch("/.netlify/functions/create-post", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        const data = await response.json();

        if (!response.ok) {
          message.textContent = `Error: ${data.error}`;
          return;
        }

        message.textContent = "Post creado correctamente.";
        form.reset();
      } catch (error) {
        message.textContent = `Error: ${error.message}`;
      }
    });
  </script>
</DashboardLayout>