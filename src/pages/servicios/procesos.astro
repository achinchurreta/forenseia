---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import Container from "../../components/ui/Container.astro";
import Button from "../../components/ui/Button.astro";
import { services } from "../../data/services";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.href.split("/").pop() },
    props: { service },
  }));
}

const { service } = Astro.props;

const sections = [
  "Problemas que resuelve",
  "Metodología aplicada",
  "Entregables",
  "Beneficios",
];
---

<BaseLayout
  title={`${service.title} | ForenseIA`}
  description={service.description}
>
  <PageHeader
    eyebrow="Servicio especializado"
    title={service.title}
    description={service.description}
  />

  <section class="py-24">
    <Container>
      <div class="grid lg:grid-cols-[1fr_360px] gap-14">
        <div class="space-y-10">
          {sections.map((section) => (
            <div class="border border-white/10 bg-white/[0.02] p-8">
              <h2 class="text-2xl font-semibold">{section}</h2>

              <p class="mt-5 text-white/55 leading-relaxed">
                Este servicio permite analizar información compleja, organizar evidencia,
                identificar riesgos, construir hallazgos y generar criterios accionables
                para investigación, auditoría, cumplimiento o toma de decisiones.
              </p>
            </div>
          ))}
        </div>

        <aside class="h-fit border border-white/10 bg-gradient-to-b from-white/[0.04] to-white/[0.01] p-8">
          <p class="text-[#C8A96B] uppercase tracking-[0.3em] text-xs">
            Diagnóstico
          </p>

          <h3 class="text-2xl font-semibold mt-5">
            ¿Necesitas una propuesta?
          </h3>

          <p class="text-white/55 leading-relaxed mt-4">
            Solicita un diagnóstico inicial para entender el alcance del caso,
            los documentos disponibles y la estrategia de análisis.
          </p>

          <div class="mt-8">
            <Button href="/contacto">
              Solicitar propuesta
            </Button>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>