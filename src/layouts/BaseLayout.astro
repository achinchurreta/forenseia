---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title?: string;
}

const { title = "ForenseIA" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>{title}</title>

    <meta
      name="description"
      content="ForenseIA - Inteligencia artificial, auditoría forense, OSINT e inteligencia patrimonial."
    />
  </head>

  <body class="bg-black text-white antialiased">

    <Header />

    <main>
      <slot />
    </main>

    <Footer />

  </body>
</html>